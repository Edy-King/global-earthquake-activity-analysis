      "mean_average_precision": 0.6994251436420841,
      "mean_recall": 0.9191010934819897,
      "mean_balanced_accuracy": 0.6165529670580405,
      "mean_brier_score": 0.27542062837384157
    },
    "output_files": [
      "outputs/spatial_holdout_by_region.csv",
      "outputs/spatial_holdout_summary.csv",
      "outputs/random_split_extended_metrics.csv"
    ]
  }
}